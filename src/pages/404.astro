---
import Base from '../layouts/Base.astro';
---
<Base
  title="Not found — Matt Bachmann"
  description="That page doesn't exist. Head back to the homepage."
>
  <main class="wrap">
    <header class="phead">
      <span class="kicker">404</span>
      <h1>Nothing here</h1>
      <p class="lede">
        That page wandered off, like a half-finished gadget in the electronics
        drawer. Let's get you back on track.
      </p>
      <div class="cta" style="margin-top: 8px; display: flex; gap: 14px; flex-wrap: wrap;">
        <a class="btn btn--primary" href="/">Back home <span class="arr">→</span></a>
        <a class="btn btn--ghost" href="/software">See the work</a>
      </div>
    </header>
  </main>
</Base>
