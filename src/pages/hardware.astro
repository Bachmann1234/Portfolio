---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import BuildCard from '../components/BuildCard.astro';

const builds = (await getCollection('builds')).sort(
  (a, b) => a.data.order - b.data.order,
);
---
<Base
  title="Hardware — Matt Bachmann"
  description="Hardware builds from Matt Bachmann's electronics drawer: microcontroller projects, custom circuits, and 3D-printed gadgets that solve small, real problems."
  active="hardware"
>
  <main class="wrap">
    <header class="phead">
      <span class="kicker">02 / Workbench</span>
      <h1>Hardware</h1>
    </header>

    <div class="grid">
      {builds.map((entry, i) => (
        <BuildCard build={entry.data} index={i + 1} eager={i < 4} />
      ))}
    </div>
  </main>
</Base>

<style is:global>
  .grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
  .build { padding: 0; }
  .build__media { height: 240px; overflow: hidden; border-bottom: 1px solid var(--rule-soft); }
  .build__media img { width: 100%; height: 100%; object-fit: cover; }
  .build__media--empty { display: grid; place-items: center; background: var(--tint); }
  .build__media--empty span { font-family: var(--font-mono); font-size: 13px; color: var(--ink-faint); }

  /* swipeable multi-photo gallery (CSS scroll-snap; dots enhanced by site.js) */
  .build__gallery { position: relative; }
  .gallery__track { display: flex; height: 240px; overflow-x: auto; scroll-snap-type: x mandatory; scrollbar-width: none; -webkit-overflow-scrolling: touch; }
  .gallery__track::-webkit-scrollbar { display: none; }
  .gallery__track img { flex: 0 0 100%; width: 100%; height: 100%; object-fit: cover; scroll-snap-align: center; }
  .gallery__dots { position: absolute; bottom: 11px; left: 0; right: 0; display: flex; gap: 7px; justify-content: center; pointer-events: none; }
  .gdot { width: 7px; height: 7px; padding: 0; border: none; border-radius: 50%; cursor: pointer; pointer-events: auto; background: rgba(255,255,255,.45); box-shadow: 0 0 0 1px rgba(0,0,0,.3); transition: background .2s ease; }
  .gdot.on { background: #fff; }
  /* hover arrows for mouse users; touch devices just swipe */
  .gallery__nav { position: absolute; top: 50%; transform: translateY(-50%); width: 34px; height: 34px; display: grid; place-items: center; padding: 0; border: none; border-radius: 50%; cursor: pointer; background: rgba(0,0,0,.42); color: #fff; font-family: var(--font-display); font-size: 22px; line-height: 1; opacity: 0; transition: opacity .18s ease, background .18s ease; }
  .gallery__nav--prev { left: 10px; }
  .gallery__nav--next { right: 10px; }
  .build__gallery:hover .gallery__nav, .gallery__nav:focus-visible { opacity: 1; }
  .gallery__nav:hover { background: rgba(0,0,0,.68); }
  @media (hover: none) { .gallery__nav { display: none; } }

  .build__body { padding: 24px 28px 26px; display: flex; flex-direction: column; flex: 1; }
  .build__top { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; }
  .build h3 { font-size: 25px; letter-spacing: -0.02em; margin-bottom: 8px; }
  .build .idx { font-family: var(--font-mono); font-size: 12px; color: var(--ink-faint); letter-spacing: 0.1em; }
  .build p { color: var(--ink-soft); font-size: 16px; margin: 0 0 16px; }
  .build .tags { margin-top: auto; }
  @media (max-width: 760px){ .grid { grid-template-columns: 1fr; } }
</style>
