<!DOCTYPE html>
<!-- GENERATED by build_projects.py from projects.yaml.
     Edit templates/software.html.j2 for layout; edit project CONTENT in
     projects.yaml. Do not hand-edit this file. -->
<html lang="en" data-theme="forest" data-font="journal" data-mode="dark">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Software — Matt Bachmann</title>
<link rel="stylesheet" href="assets/site.css">
<style>
  .grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 22px; padding-bottom: 8px; }
  .proj { padding: 30px 30px 26px; }
  .proj__media { margin: -30px -30px 22px; height: 210px; background: var(--tint); border-bottom: 1px solid var(--rule-soft); display: grid; place-items: center; padding: 16px; overflow: hidden; }
  .proj__media img { max-width: 100%; max-height: 100%; object-fit: contain; border-radius: 6px; box-shadow: var(--shadow); }
  .proj__top { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 14px; }
  .proj__stars { font-family: var(--font-mono); font-size: 12.5px; color: var(--ink-faint); display: inline-flex; align-items: center; gap: 5px; }
  .proj h3 { font-size: 27px; margin-bottom: 8px; letter-spacing: -0.02em; }
  .proj p { color: var(--ink-soft); font-size: 16.5px; margin: 0 0 18px; }
  .proj__credit { font-size: 13px; color: var(--ink-faint); margin: 0 0 18px; font-style: italic; }
  .proj__credit a { color: var(--ink-faint); }
  .proj__foot { margin-top: auto; display: flex; align-items: center; justify-content: space-between; gap: 12px; padding-top: 16px; border-top: 1px solid var(--rule-soft); }
  .proj__links { display: flex; gap: 16px; }
  .status { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 8px; border-radius: 5px; }
  .status--live { color: var(--accent-deep); background: var(--accent-tint); }
  .status--retired { color: var(--ink-faint); background: var(--tint); }
  .addcard {
    border: 1.5px dashed var(--rule); background: transparent; box-shadow: none;
    display: grid; place-items: center; text-align: center; padding: 40px; min-height: 220px;
  }
  .addcard:hover { transform: none; box-shadow: none; border-color: var(--ink-faint); }
  .addcard .plus { font-family: var(--font-display); font-size: 40px; color: var(--ink-faint); line-height: 1; }
  .addcard p { font-family: var(--font-mono); font-size: 13px; color: var(--ink-faint); margin: 12px 0 0; max-width: 26ch; }
  @media (max-width: 760px){ .grid { grid-template-columns: 1fr; } }
</style>
</head>
<body>

<header class="nav"><div class="nav__in">
  <a class="brand" href="index.html"><span class="brand__mark">B</span> Matt Bachmann</a>
  <nav class="navlinks">
    <a class="navlink" href="index.html">Home</a>
    <a class="navlink" href="software.html" aria-current="page">Software</a>
    <a class="navlink" href="hardware.html">Hardware</a>
    <a class="navlink" href="resume.html">Résumé</a>
  </nav>
</div></header>

<main class="wrap">
  <header class="phead">
    <span class="kicker">01 / Work</span>
    <h1>Software</h1>
    <p class="lede">A running list of things I have built: open-source tools, native apps, and small utilities that make a day a little better. It grows as I ship.</p>
  </header>

  <div class="grid">

{% for p in projects %}
    <article class="card proj reveal{% if loop.index <= 2 %} in{% endif %}">
{% if p.image %}
      <div class="proj__media"><img src="{{ p.image }}" alt="{{ p.name }} screenshot"></div>
{% endif %}
      <div class="proj__top">
        <div class="tags"><span class="tag tag--lang">{{ p.lang }}</span>{% for t in p.tags %}<span class="tag">{{ t }}</span>{% endfor %}</div>
{% if p.stars is defined %}
        <span class="proj__stars">★ {{ p.stars }}</span>
{% elif p.status is defined %}
        <span class="status status--{{ p.status.kind }}">{{ p.status.label }}</span>
{% endif %}
      </div>
      <h3>{{ p.name }}</h3>
      <p>{{ p.blurb }}</p>
{% if p.credit %}
      <p class="proj__credit">{{ p.credit }}</p>
{% endif %}
      <div class="proj__foot">
        <div class="proj__links">
{% for l in p.links %}
          <a class="tlink" href="{{ l.url }}">{{ l.label }}</a>
{% endfor %}
        </div>
      </div>
    </article>

{% endfor %}
    <a class="card proj addcard reveal" href="https://github.com/Bachmann1234" style="text-decoration:none;color:inherit">
      <div>
        <div class="plus">+</div>
        <p>More on GitHub — the list keeps growing.</p>
      </div>
    </a>

  </div>
</main>

<footer class="foot"><div class="foot__in">
  <small>© 2026 Matt Bachmann · Medford, MA</small>
  <div class="foot__links">
    <a class="tlink" href="https://github.com/Bachmann1234">GitHub</a>
    <a class="tlink" href="https://bsky.app/profile/mattbachmann.dev">Bluesky</a>
  </div>
</div></footer>

<script src="assets/site.js"></script>
</body>
</html>
